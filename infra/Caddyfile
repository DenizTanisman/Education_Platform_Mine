# IAU AI Platform — Caddy reverse proxy (dev-friendly)
#
# In dev/local we listen on :80 and reverse-proxy to the app service.
# For production with a real domain, replace `:80` with the domain name
# (e.g. `iau.example.com`) and Caddy will auto-provision TLS via ACME.

{
	# Global options
	auto_https off
	admin off
}

:80 {
	encode gzip

	# Basic security headers. SAMEORIGIN (not DENY) on X-Frame-Options so the
	# education page's own /pdfs/<slug>.pdf iframe renders.
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	# Static-serve education PDFs out of the app/public/pdfs bind mount.
	# Next.js standalone output does NOT serve public/ files; doing it here
	# is faster anyway (no Node hop, native file streaming).
	handle_path /pdfs/* {
		root * /srv/pdfs
		file_server
	}

	# Reverse proxy everything else to the Next.js app.
	reverse_proxy app:3000

	log {
		output stdout
		format console
	}
}
