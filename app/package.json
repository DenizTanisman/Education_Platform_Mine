{
  "name": "iau-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Next.js app + Prisma client for the IAU AI platform.",
  "engines": {
    "node": ">=20.6.0"
  },
  "scripts": {
    "prisma": "prisma",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "studio": "prisma studio",
    "generate": "prisma generate",
    "ingest": "node --import tsx scripts/ingest-content.ts",
    "ingest:dry-run": "node --import tsx scripts/ingest-content.ts --dry-run",
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test scripts/*.test.ts lib/*.test.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "adm-zip": "^0.5.16",
    "bcryptjs": "^2.4.3",
    "jose": "^5.9.6",
    "next": "^15.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.3",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
