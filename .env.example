# ---------------------------------------------------------------------------
# IAU AI Platform — environment template
# ---------------------------------------------------------------------------
# Usage:
#   cp .env.example .env
#   # then replace the change_me_* values with real secrets
#
# Rules (00_MASTER_PROMPT.md §2.4):
#   - no hardcoded secrets in code — everything goes through process.env
#   - generate strong random values for JWT_SECRET and RUNNER_SHARED_SECRET:
#       openssl rand -hex 32
# ---------------------------------------------------------------------------

# ---- Postgres ----
POSTGRES_USER=iau_user
POSTGRES_PASSWORD=change_me_dev_password
POSTGRES_DB=iau_platform

# ---- App (Next.js) ----
APP_PORT=3000
NODE_ENV=development
# Used by services *inside* the compose network (app, runner) AND by the
# one-off prisma migration container that `make migrate` spins up on the
# same `internal_net`.
DATABASE_URL=postgresql://iau_user:change_me_dev_password@postgres:5432/iau_platform
# Used by host-side tooling (ingest from host, prisma studio, ad-hoc psql).
# Same database, different hostname/port (loopback exposure on 5433).
LOCAL_DATABASE_URL=postgresql://iau_user:change_me_dev_password@127.0.0.1:5433/iau_platform

# ---- Auth ----
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_generate_with_openssl_rand_hex_32

# ---- Runner ----
RUNNER_PORT=4000
RUNNER_URL=http://runner:4000
# Shared secret for x-runner-secret header (app <-> runner)
# Generate with: openssl rand -hex 32
RUNNER_SHARED_SECRET=change_me_generate_with_openssl_rand_hex_32

# ---- Caddy (reverse proxy) ----
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
